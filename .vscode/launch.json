{
    "configurations": [
        {
            "name": "Debug nixmac Tauri Rust (LLDB)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/target/debug/nixmac",
            "cwd": "${workspaceFolder}/apps/native/src-tauri",
            "env": {
                "RUST_LOG": "trace",
                "PATH": "${workspaceFolder}/.devenv/profile/bin:${env:PATH}",
                "DYLD_LIBRARY_PATH": "${workspaceFolder}/.devenv/profile/lib:${env:DYLD_LIBRARY_PATH}"
            },
        },
        {
            "name": "Attach to nixmac Rust (LLDB)",
            "type": "lldb",
            "request": "attach",
            "pid": "${command:pickProcess}"
        },
        {
            "name": "Debug AI Engine Eval (Python)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/apps/eval/run_evals.py",
            "args": ["--rows", "1,2,3", "--ollama-url", "http://localhost:11434"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/apps/ai-engine-eval:${env:PYTHONPATH}"
            }
        },
        {
            "name": "Calculate AI Engine Eval Stats (Python)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/apps/eval/calc_stats.py",
            "args": ["-i", "${workspaceFolder}/apps/eval/data/results"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/apps/ai-engine-eval:${env:PYTHONPATH}"
            }
        },
        {
            "name": "Update nix-darwin docs (Python)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/update-nix-darwin_docs.py"
        }
    ]
}