# E2E test runner secrets — encrypt with SOPS before committing
#
# To create the encrypted file:
#   1. Copy this to e2e.yaml and fill in values
#   2. sops --encrypt --age <age-public-key> e2e.yaml > e2e.enc.yaml
#   3. rm e2e.yaml
#   4. Commit e2e.enc.yaml
#
# The SOPS_AGE_KEY (private key) goes in GitHub Secrets as the only secret needed.

mac_host: "38.79.97.120"
mac_user: "admin"
mac_ssh_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  ...your SSH private key...
  -----END OPENSSH PRIVATE KEY-----
mac_admin_pw: "your-admin-password"
