{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@hono/trpc-server": "^0.4.0",
    "@nixmac/api": "workspace:*",
    "@nixmac/auth": "workspace:*",
    "@nixmac/db": "workspace:*",
    "@nixmac/hono-api": "workspace:*",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aws-sdk/client-iam": "^3.1014.0",
    "@aws-sdk/client-ssm": "^3.1014.0",
    "@nixmac/config": "workspace:*",
    "@types/bun": "catalog:",
    "alchemy": "^0.90.0",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
