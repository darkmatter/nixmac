// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Compact 1`] = `"<div class="rounded-lg border p-4 border-border bg-secondary/30"><div class="flex gap-3"><div class="mt-0.5 size-5 flex-shrink-0 text-primary"><svg aria-label="Information" class="size-full" fill="none" role="img" stroke="currentColor" viewBox="0 0 24 24"><title>Information</title><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg></div><div class="flex-1"><h4 class="mb-1 font-medium text-sm">Quick Tip</h4><p class="text-muted-foreground text-xs leading-relaxed">Use ⌘+Shift+O to quickly open the nixmac interface.</p></div></div></div>"`;

exports[`Default 1`] = `"<div class="rounded-lg border p-4 border-border bg-secondary/30"><div class="flex gap-3"><div class="mt-0.5 size-5 flex-shrink-0 text-primary"><svg aria-label="Information" class="size-full" fill="none" role="img" stroke="currentColor" viewBox="0 0 24 24"><title>Information</title><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg></div><div class="flex-1"><h4 class="mb-1 font-medium text-sm">Why does nixmac need these permissions?</h4><p class="text-muted-foreground text-xs leading-relaxed">nixmac manages your macOS system declaratively, similar to NixOS. It needs access to configuration files, the ability to install packages, and permission to modify system settings to provide a complete system management experience.</p></div></div></div>"`;

exports[`Feature Highlight 1`] = `"<div class="rounded-lg border p-4 border-console-success/20 bg-console-success/5"><div class="flex gap-3"><div class="mt-0.5 size-5 flex-shrink-0 text-console-success"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles size-full" aria-hidden="true"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"></path><path d="M20 2v4"></path><path d="M22 4h-4"></path><circle cx="4" cy="20" r="2"></circle></svg></div><div class="flex-1"><h4 class="mb-1 font-medium text-sm">AI-Powered Configuration</h4><p class="text-muted-foreground text-xs leading-relaxed">Our AI assistant can help you discover new packages, optimize your setup, and suggest improvements based on your usage patterns.</p></div></div></div>"`;

exports[`Info Variant 1`] = `"<div class="rounded-lg border p-4 border-primary/20 bg-primary/5"><div class="flex gap-3"><div class="mt-0.5 size-5 flex-shrink-0 text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-info size-full" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg></div><div class="flex-1"><h4 class="mb-1 font-medium text-sm">Getting Started</h4><p class="text-muted-foreground text-xs leading-relaxed">This setup wizard will guide you through configuring nixmac for your system. The process typically takes 2-3 minutes to complete.</p></div></div></div>"`;

exports[`Long Content 1`] = `"<div class="rounded-lg border p-4 border-border bg-secondary/30"><div class="flex gap-3"><div class="mt-0.5 size-5 flex-shrink-0 text-primary"><svg aria-label="Information" class="size-full" fill="none" role="img" stroke="currentColor" viewBox="0 0 24 24"><title>Information</title><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg></div><div class="flex-1"><h4 class="mb-1 font-medium text-sm">Detailed System Configuration Process</h4><p class="text-muted-foreground text-xs leading-relaxed">This comprehensive setup process involves multiple steps including permission verification, system package installation, configuration file generation, service management, and final system validation. Each step is carefully orchestrated to ensure your system remains stable and functional throughout the entire process. The declarative nature of nixmac means that every change is predictable and reproducible across different machines and environments.</p></div></div></div>"`;

exports[`Multiple Cards 1`] = `"<div class="space-y-4"><div class="rounded-lg border p-4 border-primary/20 bg-primary/5"><div class="flex gap-3"><div class="mt-0.5 size-5 flex-shrink-0 text-primary"><svg aria-label="Information" class="size-full" fill="none" role="img" stroke="currentColor" viewBox="0 0 24 24"><title>Information</title><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg></div><div class="flex-1"><h4 class="mb-1 font-medium text-sm">Before You Start</h4><p class="text-muted-foreground text-xs leading-relaxed">This is important information you should know before proceeding.</p></div></div></div><div class="rounded-lg border p-4 border-amber-500/20 bg-amber-500/5"><div class="flex gap-3"><div class="mt-0.5 size-5 flex-shrink-0 text-amber-600"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-triangle-alert size-full" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path></svg></div><div class="flex-1"><h4 class="mb-1 font-medium text-sm">Backup Warning</h4><p class="text-muted-foreground text-xs leading-relaxed">Make sure to backup your important files before making system changes.</p></div></div></div><div class="rounded-lg border p-4 border-console-success/20 bg-console-success/5"><div class="flex gap-3"><div class="mt-0.5 size-5 flex-shrink-0 text-console-success"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big size-full" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"></path><path d="m9 11 3 3L22 4"></path></svg></div><div class="flex-1"><h4 class="mb-1 font-medium text-sm">Changes Applied</h4><p class="text-muted-foreground text-xs leading-relaxed">Your configuration has been successfully applied to the system.</p></div></div></div></div>"`;

exports[`Security Info 1`] = `"<div class="rounded-lg border p-4 border-primary/20 bg-primary/5"><div class="flex gap-3"><div class="mt-0.5 size-5 flex-shrink-0 text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield size-full" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path></svg></div><div class="flex-1"><h4 class="mb-1 font-medium text-sm">Security &amp; Privacy</h4><p class="text-muted-foreground text-xs leading-relaxed">nixmac only accesses the specific directories and resources it needs. All system modifications are transparent and can be reviewed before applying.</p></div></div></div>"`;

exports[`Success 1`] = `"<div class="rounded-lg border p-4 border-console-success/20 bg-console-success/5"><div class="flex gap-3"><div class="mt-0.5 size-5 flex-shrink-0 text-console-success"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big size-full" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"></path><path d="m9 11 3 3L22 4"></path></svg></div><div class="flex-1"><h4 class="mb-1 font-medium text-sm">Setup Complete!</h4><p class="text-muted-foreground text-xs leading-relaxed">Your system is now configured and ready to use. You can start managing your macOS setup declaratively through nixmac.</p></div></div></div>"`;

exports[`Technical Details 1`] = `"<div class="rounded-lg border p-4 border-border bg-secondary/30"><div class="flex gap-3"><div class="mt-0.5 size-5 flex-shrink-0 text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-terminal size-full" aria-hidden="true"><path d="M12 19h8"></path><path d="m4 17 6-6-6-6"></path></svg></div><div class="flex-1"><h4 class="mb-1 font-medium text-sm">How it Works</h4><p class="text-muted-foreground text-xs leading-relaxed">nixmac uses nix-darwin and home-manager to provide declarative system configuration. Your entire system state is defined in version-controlled configuration files.</p></div></div></div>"`;

exports[`Warning 1`] = `"<div class="rounded-lg border p-4 border-amber-500/20 bg-amber-500/5"><div class="flex gap-3"><div class="mt-0.5 size-5 flex-shrink-0 text-amber-600"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-triangle-alert size-full" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path></svg></div><div class="flex-1"><h4 class="mb-1 font-medium text-sm">Backup Recommended</h4><p class="text-muted-foreground text-xs leading-relaxed">Before making system changes, we recommend creating a backup of your current configuration. This ensures you can restore your system if needed.</p></div></div></div>"`;
