exports[`Backup Notification 1`] = `"<div class="text-center mb-8"><div class="mb-4 flex items-center justify-center gap-2"><div class="flex size-12 items-center justify-center rounded-lg bg-primary"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield size-7 text-primary-foreground" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path></svg></div></div><h1 class="mb-2 font-semibold text-3xl tracking-tight">System Backup</h1><p class="text-muted-foreground">Before making changes to your system configuration, we recommend creating a backup of your current setup.</p></div>"`;

exports[`Compact 1`] = `"<div class="text-center mb-4"><h1 class="mb-1 font-semibold text-lg tracking-tight">System Permissions</h1><p class="text-muted-foreground text-sm">Grant the following permissions to continue</p></div>"`;

exports[`Compact With Icon 1`] = `"<div class="text-center mb-4"><div class="mb-4 flex items-center justify-center gap-2"><div class="flex size-12 items-center justify-center rounded-lg bg-primary"><svg aria-label="Console icon" class="size-7 text-primary-foreground" fill="none" role="img" stroke="currentColor" viewBox="0 0 24 24"><title>Console icon</title><path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg></div></div><h1 class="mb-1 font-semibold text-lg tracking-tight">System Permissions</h1><p class="text-muted-foreground text-sm">Grant the following permissions to continue</p></div>"`;

exports[`Config Management 1`] = `"<div class="text-center mb-8"><div class="mb-4 flex items-center justify-center gap-2"><div class="flex size-12 items-center justify-center rounded-lg bg-primary"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-cog size-7 text-primary-foreground" aria-hidden="true"><path d="M11 10.27 7 3.34"></path><path d="m11 13.73-4 6.93"></path><path d="M12 22v-2"></path><path d="M12 2v2"></path><path d="M14 12h8"></path><path d="m17 20.66-1-1.73"></path><path d="m17 3.34-1 1.73"></path><path d="M2 12h2"></path><path d="m20.66 17-1.73-1"></path><path d="m20.66 7-1.73 1"></path><path d="m3.34 17 1.73-1"></path><path d="m3.34 7 1.73 1"></path><circle cx="12" cy="12" r="2"></circle><circle cx="12" cy="12" r="8"></circle></svg></div></div><h1 class="mb-2 font-semibold text-3xl tracking-tight">Configuration Manager</h1><p class="text-muted-foreground">Manage your system configuration files, packages, and settings from a single declarative interface.</p></div>"`;

exports[`Default 1`] = `"<div class="text-center mb-8"><div class="mb-4 flex items-center justify-center gap-2"><div class="flex size-12 items-center justify-center rounded-lg bg-primary"><svg aria-label="Console icon" class="size-7 text-primary-foreground" fill="none" role="img" stroke="currentColor" viewBox="0 0 24 24"><title>Console icon</title><path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg></div></div><h1 class="mb-2 font-semibold text-3xl tracking-tight">System Permissions</h1><p class="text-muted-foreground">To manage your macOS system declaratively, nixmac needs the following permissions</p></div>"`;

exports[`Installation Progress 1`] = `"<div class="text-center mb-8"><div class="mb-4 flex items-center justify-center gap-2"><div class="flex size-12 items-center justify-center rounded-lg bg-primary"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-download size-7 text-primary-foreground" aria-hidden="true"><path d="M12 15V3"></path><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><path d="m7 10 5 5 5-5"></path></svg></div></div><h1 class="mb-2 font-semibold text-3xl tracking-tight">Installing Packages</h1><p class="text-muted-foreground">nixmac is installing the required system packages and configuring your environment. This may take a few minutes.</p></div>"`;

exports[`Long Content 1`] = `"<div class="text-center mb-8"><div class="mb-4 flex items-center justify-center gap-2"><div class="flex size-12 items-center justify-center rounded-lg bg-primary"><svg aria-label="Console icon" class="size-7 text-primary-foreground" fill="none" role="img" stroke="currentColor" viewBox="0 0 24 24"><title>Console icon</title><path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg></div></div><h1 class="mb-2 font-semibold text-3xl tracking-tight">Advanced System Configuration and Package Management Interface</h1><p class="text-muted-foreground">This comprehensive system management tool provides declarative configuration capabilities for macOS through nix-darwin and home-manager integration. Manage packages, services, and system settings through version-controlled configuration files.</p></div>"`;

exports[`Multiple Headers 1`] = `"<div class="max-w-2xl space-y-8"><div class="text-center mb-8"><div class="mb-4 flex items-center justify-center gap-2"><div class="flex size-12 items-center justify-center rounded-lg bg-primary"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield size-7 text-primary-foreground" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path></svg></div></div><h1 class="mb-2 font-semibold text-3xl tracking-tight">Step 1: Permissions</h1><p class="text-muted-foreground">First step in the onboarding process</p></div><div class="text-center mb-4"><h1 class="mb-1 font-semibold text-lg tracking-tight">Step 2: Configuration</h1><p class="text-muted-foreground text-sm">Compact version for step navigation</p></div><div class="text-center mb-8"><div class="mb-4 flex items-center justify-center gap-2"><div class="flex size-12 items-center justify-center rounded-lg bg-primary"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big size-7 text-primary-foreground" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"></path><path d="m9 11 3 3L22 4"></path></svg></div></div><h1 class="mb-2 font-semibold text-3xl tracking-tight">Step 3: Complete</h1><p class="text-muted-foreground">Final step with completion icon</p></div></div>"`;

exports[`Responsive Comparison 1`] = `"<div class="grid grid-cols-1 gap-8 lg:grid-cols-2"><div class="rounded-lg border p-6"><h3 class="mb-4 font-medium text-sm">Full Size</h3><div class="text-center mb-8"><div class="mb-4 flex items-center justify-center gap-2"><div class="flex size-12 items-center justify-center rounded-lg bg-primary"><svg aria-label="Console icon" class="size-7 text-primary-foreground" fill="none" role="img" stroke="currentColor" viewBox="0 0 24 24"><title>Console icon</title><path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg></div></div><h1 class="mb-2 font-semibold text-3xl tracking-tight">System Permissions</h1><p class="text-muted-foreground">To manage your macOS system declaratively, nixmac needs the following permissions</p></div></div><div class="rounded-lg border p-6"><h3 class="mb-4 font-medium text-sm">Compact</h3><div class="text-center mb-4"><h1 class="mb-1 font-semibold text-lg tracking-tight">System Permissions</h1><p class="text-muted-foreground text-sm">Grant the following permissions to continue</p></div></div></div>"`;

exports[`Security Settings 1`] = `"<div class="text-center mb-8"><div class="mb-4 flex items-center justify-center gap-2"><div class="flex size-12 items-center justify-center rounded-lg bg-primary"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-lock size-7 text-primary-foreground" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg></div></div><h1 class="mb-2 font-semibold text-3xl tracking-tight">Security &amp; Privacy</h1><p class="text-muted-foreground">Configure security settings and privacy permissions for your nixmac installation.</p></div>"`;

exports[`Setup Complete 1`] = `"<div class="text-center mb-8"><div class="mb-4 flex items-center justify-center gap-2"><div class="flex size-12 items-center justify-center rounded-lg bg-primary"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big size-7 text-primary-foreground" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"></path><path d="m9 11 3 3L22 4"></path></svg></div></div><h1 class="mb-2 font-semibold text-3xl tracking-tight">Setup Complete!</h1><p class="text-muted-foreground">Your system is now configured and ready to use. You can start managing your macOS setup declaratively through nixmac.</p></div>"`;

exports[`Terminal Access 1`] = `"<div class="text-center mb-8"><div class="mb-4 flex items-center justify-center gap-2"><div class="flex size-12 items-center justify-center rounded-lg bg-primary"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-terminal size-7 text-primary-foreground" aria-hidden="true"><path d="M12 19h8"></path><path d="m4 17 6-6-6-6"></path></svg></div></div><h1 class="mb-2 font-semibold text-3xl tracking-tight">Terminal Integration</h1><p class="text-muted-foreground">nixmac provides seamless terminal integration for advanced system management and debugging.</p></div>"`;

exports[`Text Only 1`] = `"<div class="text-center mb-8"><h1 class="mb-2 font-semibold text-3xl tracking-tight">Welcome to nixmac</h1><p class="text-muted-foreground">Let's get your macOS system configured declaratively</p></div>"`;
