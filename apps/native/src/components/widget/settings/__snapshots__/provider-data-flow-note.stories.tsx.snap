exports[`Cloud No Key Yet 1`] = `"<div class="w-[420px] rounded-lg border bg-background p-4"><p class="text-muted-foreground text-xs">Your prompts and config context are sent to OpenRouter or OpenAI, based on the API key you configure to process your request. They are not sent to nixmac's servers.</p></div>"`;

