exports[`Full Disk Access Required 1`] = `"<div style="width: 280px; height: 400px; position: relative;"><div class="absolute inset-0 z-10 flex items-center justify-center bg-background/95 backdrop-blur-sm"><div class="h-full w-full max-h-[600px] max-w-[800px] p-5"><div class="flex h-full w-full flex-col overflow-hidden rounded-2xl border border-white/10 p-6" style="background: radial-gradient(at 50% 100%, rgba(30, 30, 30, 0.98) 0%, rgba(20, 20, 20, 0.95) 50%, rgba(15, 15, 15, 0.92) 100%);"><div class="min-h-0 flex-1"><div class="flex h-full flex-col items-center justify-center gap-5" style="opacity: MOTION;"><div class="flex h-14 w-14 items-center justify-center rounded-full bg-rose-300/10"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-triangle-alert h-7 w-7 text-rose-300" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path></svg></div><h2 class="text-center font-semibold text-white text-lg">Full Disk Access is required for activation</h2><div class="w-full max-w-xl"></div><p class="max-w-xl rounded-lg border border-teal-400/30 bg-teal-400/10 px-4 py-2 text-center font-medium text-sm text-teal-200">No changes were made to your system.</p><p class="max-h-48 w-full max-w-xl overflow-y-auto rounded-lg bg-black/30 px-6 py-3 text-center font-mono text-xs text-zinc-400">Operation not permitted while reading /etc/sudoers.d</p><p class="max-w-xl text-center text-sm text-zinc-300">darwin-rebuild requires Full Disk Access. Make sure nixmac is in your Applications folder (not running from the install disk image), then grant access in System Settings → Privacy &amp; Security → Full Disk Access.</p></div><div class="flex h-full w-full flex-col" style="display: none !important;"><div class="mb-4 flex items-center just