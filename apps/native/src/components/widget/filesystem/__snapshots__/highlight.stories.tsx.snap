exports[`Flake Nix 1`] = `"<pre class="m-0 whitespace-pre rounded-md border border-border bg-card p-4 font-mono text-[12px] leading-[1.6]"><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">1</span>{</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">2</span>  <span class="text-teal-300">description</span> = <span class="text-emerald-300">"Farhan's nix-darwin systems"</span>;</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">3</span>  inputs.nixpkgs.<span class="text-teal-300">url</span> = <span class="text-emerald-300">"github:NixOS/nixpkgs/nixpkgs-unstable"</span>;</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">4</span></div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">5</span>  <span class="text-teal-300">outputs</span> = inputs@{ nix-darwin, ... }: {</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">6</span>    darwinConfigurations.<span class="text-emerald-300">"Farhans-MacBook-Pro-26"</span> =</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">7</span>      nix-darwin.lib.darwinSystem {</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">8</span>        <span class="text-teal-300">modules</span> = [</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">9</span>          ./modules/darwin/packages.nix</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">10</span>          ./modules/darwin/homebrew.nix    <span class="text-muted-foreground italic"># casks, taps, formulae</span></div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">11</span>        ];</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">12</span>      };</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">13</span>  };</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">14</span>}</div></pre>"`;

exports[`Homebrew Module 1`] = `"<pre class="m-0 whitespace-pre rounded-md border border-border bg-card p-4 font-mono text-[12px] leading-[1.6]"><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">1</span>{</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">2</span>  <span class="text-teal-300">homebrew</span> = {</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">3</span>    <span class="text-teal-300">enable</span> = <span class="text-sky-300">true</span>;</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">4</span>    onActivation.<span class="text-teal-300">cleanup</span> = <span class="text-emerald-300">"zap"</span>;</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">5</span>    <span class="text-teal-300">casks</span> = [</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">6</span>      <span class="text-emerald-300">"rectangle"</span></div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">7</span>      <span class="text-emerald-300">"1password"</span></div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">8</span>    ];</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">9</span>  };</div><div class="whitespace-pre"><span class="inline-block w-7 select-none pr-2 text-right text-muted-foreground tabular-nums">10</span>}</div></pre>"`;

exports[`Single Attr Line 1`] = `"<code class="rounded-md border border-border bg-card px-3 py-2 font-mono text-[12px]"><span class="text-sky-300">homebrew</span>.casks = [ <span class="text-emerald-300">"docker"</span> ];</code>"`;
