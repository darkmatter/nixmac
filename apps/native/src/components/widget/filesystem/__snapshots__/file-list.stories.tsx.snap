exports[`Untracked Section 1`] = `"<div class="grid gap-3" style="grid-template-columns: minmax(0px, 1fr) 360px;"><div class="overflow-hidden rounded-lg border border-border bg-card/40"><div class="h-[520px] w-[640px]"><div class="flex min-h-0 flex-col"><div class="shrink-0 border-border/50 border-b px-3 pt-2.5 pb-2"><div class="flex h-7 items-center gap-2 rounded-md border border-border bg-muted/40 px-2.5"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search h-3 w-3 text-muted-foreground" aria-hidden="true"><path d="m21 21-4.34-4.34"></path><circle cx="11" cy="11" r="8"></circle></svg><input placeholder="Search files…" class="flex-1 bg-transparent text-[11.5px] text-foreground outline-none placeholder:text-muted-foreground" data-testid="file-list-search" value=""></div></div><div class="min-h-0 flex-1 overflow-y-auto"><div class="border-border/50 border-b p-3"><div class="overflow-hidden rounded-lg border bg-gradient-to-b border-sky-500/30 from-sky-500/[0.06] to-sky-500/[0.02]"><div class="flex items-start gap-3 px-4 py-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-settings2 lucide-settings-2 mt-0.5 h-4 w-4 shrink-0 text-sky-400" aria-hidden="true"><path d="M14 17H5"></path><path d="M19 7h-9"></path><circle cx="17" cy="17" r="3"></circle><circle cx="7" cy="7" r="3"></circle></svg><div class="min-w-0 flex-1"><div class="flex items-start gap-2"><div class="min-w-0 flex-1 font-semibold text-[13px]">2 untracked macOS settings</div><button class="inline-flex items-center justify-center whitespace-nowrap font-medium text-sm outline-none transition-all focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 [&amp;_svg:not([class*='size-'])]:size-4 [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 hover:bg-accent dark:hover:bg-accent/50 gap-1.5 rounded-md has-[&gt;svg]:px-2.5 -mt-1 h-6 w-6 shrink-0 p-0 text-muted-foreground hover:text-foreground" data-slot="button" aria-expanded="true" aria-controls="_r_0_" aria-label="Collapse 2 untracked macOS settings"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down h-3.5 w-3.5 transition-transform" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg></button></div><div class="mt-1 text-[11.5px] text-muted-foreground leading-relaxed">Preferences you've changed in System Settings. Capture them as code so a fresh install matches.</div><div class="mt-2 flex flex-wrap gap-2 text-[10.5px] text-muted-foreground"><span class="font-mono">$ defaults read (212 known keys)</span><span>·</span><span>scanned just now</span><span>·</span><span>would land in <span class="font-mono text-foreground">modules/darwin/defaults.nix</span></span></div></div></div><div id="_r_0_"><div class="border-t px-3 py-2.5 border-sky-500/20"><div class="flex flex-wrap gap-1.5"><button class="inline-flex shrink-0 items-center justify-center whitespace-nowrap font-medium outline-none transition-all focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 [&amp;_svg:not([class*='size-'])]:size-4 [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 rounded-md px-3 has-[&gt;svg]:px-2.5 h-7 gap-1.5 bg-teal-500 text-[11px] text-background hover:bg-teal-400" data-slot="button" data-testid="track-all-custom-defaults"><svg