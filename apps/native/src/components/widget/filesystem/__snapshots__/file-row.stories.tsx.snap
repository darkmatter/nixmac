exports[`Changed 1`] = `"<div class="grid gap-3" style="grid-template-columns: minmax(0px, 1fr) 360px;"><div class="overflow-hidden rounded-lg border border-border bg-card/40"><div class="border-border/50 border-b"><div class="grid grid-cols-[auto_1fr_auto] items-start gap-3 px-3 py-2.5"><span class="mt-0.5 flex h-7 w-7 items-center justify-center rounded-md bg-amber-500/15 text-amber-400"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-app-window h-3.5 w-3.5" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="M10 4v4"></path><path d="M2 8h20"></path><path d="M6 4v4"></path></svg></span><div class="min-w-0"><div class="flex flex-wrap items-center gap-1.5"><span class="font-medium text-[12.5px]">Apps &amp; casks</span><span class="rounded-sm bg-amber-500/15 px-1 py-px font-semibold text-[9.5px] text-amber-400">+1 cask</span></div><div class="mt-0.5 truncate font-mono text-[10.5px] text-muted-foreground">modules/darwin/homebrew.nix</div><div class="mt-1 line-clamp-2 text-[11.5px] text-muted-foreground">Mac apps installed via Homebrew — Rectangle, 1Password, browsers.</div></div><div class="flex shrink-0 items-center gap-1.5"><button type="button" class="flex h-7 items-center gap-1 rounded-md border border-border bg-card/40 px-2 text-[11px] text-muted-foreground transition-colors hover:bg-card hover:text-foreground" aria-expanded="false" aria-label="Show nix source"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-braces h-3 w-3" aria-hidden="true"><path d="M8 3H7a2 2 0 0 0-2 2v5a2 2 0 0 1-2 2 2 2 0 0 1 2 2v5c0 1.1.9 2 2 2h1"></path><path d="M16 21h1a2 2 0 0 0 2-2v-5c0-1.1.9-2 2-2a2 2 0 0 1-2-2V5a2 2 0 0 0-2-2h-1"></path></svg><svg xmln