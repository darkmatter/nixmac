// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Per File Seeds 1`] = `"<div class="grid gap-2"><div class="font-semibold text-[12px]">seedForFile (per editable file)</div><table class="w-full border-collapse rounded-md border border-border text-[11px]"><thead><tr class="border-border border-b bg-card/40"><th class="px-3 py-2 text-left font-medium text-[10px] text-muted-foreground uppercase tracking-wider">File</th><th class="px-3 py-2 text-left font-medium text-[10px] text-muted-foreground uppercase tracking-wider">Seed</th></tr></thead><tbody><tr class="border-border/40 border-b last:border-b-0"><td class="px-3 py-2 align-top font-mono text-[10.5px] text-muted-foreground">flake.nix</td><td class="px-3 py-2 align-top"><pre class="m-0 whitespace-pre-wrap wrap-break-word font-mono text-[10.5px] text-teal-200 leading-normal">Change flake.nix (e.g. add the unstable nixpkgs channel): </pre></td></tr><tr class="border-border/40 border-b last:border-b-0"><td class="px-3 py-2 align-top font-mono text-[10.5px] text-muted-foreground">flake.lock</td><td class="px-3 py-2 align-top"><pre class="m-0 whitespace-pre-wrap wrap-break-word font-mono text-[10.5px] text-teal-200 leading-normal">Regenerate flake.lock.</pre></td></tr><tr class="border-border/40 border-b last:border-b-0"><td class="px-3 py-2 align-top font-mono text-[10.5px] text-muted-foreground">modules/darwin/packages.nix</td><td class="px-3 py-2 align-top"><pre class="m-0 whitespace-pre-wrap wrap-break-word font-mono text-[10.5px] text-teal-200 leading-normal">Change modules/darwin/packages.nix (e.g. add a CLI tool): </pre></td></tr><tr class="border-border/40 border-b last:border-b-0"><td class="px-3 py-2 align-top font-mono text-[10.5px] text-muted-foreground">modules/darwin/homebrew.nix</td><td class="px-3 py-2 align-top"><pre class="m-0 whitespace-pre-wrap wrap-break-word font-mono text-[10.5px] text-teal-200 leading-normal">Change modules/darwin/homebrew.nix (e.g. install Slack): </pre></td></tr><tr class="border-border/40 border-b last:border-b-0"><td class="px-3 py-2 align-top font-mono text-[10.5px] text-muted-foreground">modules/darwin/defaults.nix</td><td class="px-3 py-2 align-top"><pre class="m-0 whitespace-pre-wrap wrap-break-word font-mono text-[10.5px] text-teal-200 leading-normal">Change modules/darwin/defaults.nix (e.g. auto-hide the Dock): </pre></td></tr><tr class="border-border/40 border-b last:border-b-0"><td class="px-3 py-2 align-top font-mono text-[10.5px] text-muted-foreground">modules/darwin/services.nix</td><td class="px-3 py-2 align-top"><pre class="m-0 whitespace-pre-wrap wrap-break-word font-mono text-[10.5px] text-teal-200 leading-normal">Change modules/darwin/services.nix (e.g. enable yabai): </pre></td></tr><tr class="border-border/40 border-b last:border-b-0"><td class="px-3 py-2 align-top font-mono text-[10.5px] text-muted-foreground">modules/darwin/security.nix</td><td class="px-3 py-2 align-top"><pre class="m-0 whitespace-pre-wrap wrap-break-word font-mono text-[10.5px] text-teal-200 leading-normal">Change modules/darwin/security.nix (e.g. enable Touch ID for sudo): </pre></td></tr><tr class="border-border/40 border-b last:border-b-0"><td class="px-3 py-2 align-top font-mono text-[10.5px] text-muted-foreground">modules/home/dotfiles.nix</td><td class="px-3 py-2 align-top"><pre class="m-0 whitespace-pre-wrap wrap-break-word font-mono text-[10.5px] text-teal-200 leading-normal">Change modules/home/dotfiles.nix (e.g. switch from neovim to helix): </pre></td></tr><tr class="border-border/40 border-b last:border-b-0"><td class="px-3 py-2 align-top font-mono text-[10.5px] text-muted-foreground">modules/home/apps.nix</td><td class="px-3 py-2 align-top"><pre class="m-0 whitespace-pre-wrap wrap-break-word font-mono text-[10.5px] text-teal-200 leading-normal">Change modules/home/apps.nix (e.g. set Ghostty's theme to gruvbox): </pre></td></tr><tr class="border-border/40 border-b last:border-b-0"><td class="px-3 py-2 align-top font-mono text-[10.5px] text-muted-foreground">.sops.yaml</td><td class="px-3 py-2 align-top"><pre class="m-0 whitespace-pre-wrap wrap-break-word font-mono text-[10.5px] text-teal-200 leading-normal">Change .sops.yaml (e.g. add a new secret recipient): </pre></td></tr><tr class="border-border/40 border-b last:border-b-0"><td class="px-3 py-2 align-top font-mono text-[10.5px] text-muted-foreground">nix-overlays.nix</td><td class="px-3 py-2 align-top"><pre class="m-0 whitespace-pre-wrap wrap-break-word font-mono text-[10.5px] text-teal-200 leading-normal">Change nix-overlays.nix: </pre></td></tr></tbody></table></div>"`;
