// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Formatting Helpers 1`] = `"<div class="w-[520px] space-y-6 rounded-lg border bg-background p-6"><section class="space-y-3"><h3 class="font-medium text-sm">Path helpers</h3><div class="grid gap-2"><div class="rounded-md border p-3"><div class="font-mono text-sm">flake.nix</div><div class="text-muted-foreground text-xs">/Users/demo/.darwin</div></div><div class="rounded-md border p-3"><div class="font-mono text-sm">homebrew.nix</div><div class="text-muted-foreground text-xs">/Users/demo/.darwin/modules</div></div><div class="rounded-md border p-3"><div class="font-mono text-sm">example.age</div><div class="text-muted-foreground text-xs">secrets</div></div></div></section><section class="space-y-3"><h3 class="font-medium text-sm">Category styles</h3><div class="flex flex-wrap gap-2"><span class="rounded-md border px-2 py-1 text-xs bg-blue-500/8 border-blue-500/40 text-blue-500">System defaults</span><span class="rounded-md border px-2 py-1 text-xs bg-blue-500/8 border-blue-500/40 text-blue-500">Packages</span><span class="rounded-md border px-2 py-1 text-xs bg-gray-500/8 border-gray-500/40 text-gray-500">Theme</span></div></section></div>"`;
