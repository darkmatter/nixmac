s transition-colors border-success/40 bg-success/15 text-success"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check size-3.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg></span><div class="flex flex-col text-left"><span class="font-medium text-sm leading-tight text-muted-foreground">Config Directory</span><span class="text-xs leading-tight text-muted-foreground/70">Import or create your flake</span></div></button></li><li><button type="button" class="flex w-full items-start gap-3 rounded-lg px-3 py-3 transition-colors hover:bg-sidebar-accent/70 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" aria-label="Go to Choose Machine"><span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full border text-xs font-medium tabular-nums transition-colors border-success/40 bg-success/15 text-success"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check size-3.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg></span><div class="flex flex-col text-left"><span class="font-medium text-sm leading-tight text-muted-foreground">Choose Machine</span><span class="text-xs leading-tight text-muted-foreground/70">Pick your host configuration</span></div></button></li><li><div class="flex items-start gap-3 rounded-lg px-3 py-3 transition-colors bg-sidebar-accent" aria-current="step"><span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full border text-xs font-medium tabular-nums transition-colors border-primary bg-primary text-primary-foreground">5</span><div class="flex flex-col text-left"><span class="font-medium text-sm leading-tight text-foreground">Import Customizations</span><span class=