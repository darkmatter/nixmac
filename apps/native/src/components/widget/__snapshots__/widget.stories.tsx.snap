-nums transition-colors border-success/40 bg-success/15 text-success"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check size-3.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg></span><div class="flex flex-col text-left"><span class="font-medium text-sm leading-tight text-muted-foreground">Config Directory</span><span class="text-xs leading-tight text-muted-foreground/70">Import or create your flake</span></div></button></li><li><button type="button" class="flex w-full items-start gap-3 rounded-lg px-3 py-3 transition-colors hover:bg-sidebar-accent/70 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" aria-label="Go to Choose Machine"><span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full border text-xs font-medium tabular-nums transition-colors border-success/40 bg-success/15 text-success"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check size-3.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg></span><div class="flex flex-col text-left"><span class="font-medium text-sm leading-tight text-muted-foreground">Choose Machine</span><span class="text-xs leading-tight text-muted-foreground/70">Pick your host configuration</span></div></button></li><li><div class="flex items-start gap-3 rounded-lg px-3 py-3 transition-colors bg-sidebar-accent" aria-current="step"><span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full border text-xs font-medium tabular-nums transition-colors border-primary bg-primary text-primary-foreground">5</span><div class="flex flex-col text-left"><span class="font-medium text-sm leading-tight text-foreground">Import Customizations</span><span class="text-xs leading-tight text-muted-foreground/70">Capture existing tweaks</span></div></div></li><li><div class="flex items-start gap-3 rounded-lg px-3 py-3 transition-colors cursor-not-allowed" aria-disabled="true"><span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full border text-xs font-medium tabular-nums transition-colors border-dashed border-border/60 text-muted-foreground/50">6</span><div class="flex flex-col text-left"><span class="font-medium text-sm leading-tight text-muted-foreground/50">AI Inference</span><span class="text-xs leading-tight text-muted-foreground/40">Hosted or your own key</span></div></div></li><li><div class="flex items-start gap-3 rounded-lg px-3 py-3 transition-colors cursor-not-allowed" aria-disabled="true"><span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full border text-xs font-medium tabular-nums transition-colors border-dashed border-border/60 text-muted-foreground/50">7</span><div class="flex flex-col text-left"><span class="font-medium text-sm leading-tight text-muted-foreground/50">First Build</span><span class="text-xs leading-tight text-muted-foreground/40">Apply your configuration</span></div></div></li></ol></div></aside><div class="min-h-0 overflow-y-auto pb-8 pr-1"><main><h1 class="text-2xl font-bold">Import Customizations</h1><div class="fade-in slide-in-from-bottom-2 animate-in duration-300"><div class="flex h-full flex-col"><header class="mb-6"><p class="mt-2 max-w-prose text-pretty text-muted-foreground leading-relaxed">You only need this if you've set up this Mac by hand and don't want those tweaks overwritten when your flake is applied. If your config already reflects how you like things, skip it.</p></header><div class="flex-1"><div class="mb-4 flex items-center gap-2"><span class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-2.5 py-0.5 font-medium text-primary text-xs"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox=