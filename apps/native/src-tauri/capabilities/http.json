{
  "identifier": "http-capability",
  "windows": [
    "main"
  ],
  "description": "Allows HTTP requests and body management",
  "permissions": [
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://localhost:*/**"
        },
        {
          "url": "https://localhost:*/**"
        },
        {
          "url": "https://nixmac.com/**"
        }
      ]
    },
    "opener:default",
    "http:default",
    "os:default"
  ]
}