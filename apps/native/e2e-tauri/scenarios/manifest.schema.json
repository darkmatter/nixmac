{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/darkmatter/nixmac/apps/native/e2e-tauri/scenarios/manifest.schema.json",
  "title": "nixmac E2E Scenario Manifest",
  "type": "object",
  "required": ["scenarios"],
  "properties": {
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "lane",
          "title",
          "summary",
          "coverage",
          "riskAreas",
          "changePatterns",
          "knownGaps",
          "currentSpec",
          "currentScript",
          "status",
          "requiredForDefaultPrPack"
        ],
        "properties": {
          "name": { "type": "string" },
          "lane": { "type": "string", "enum": ["browser", "tauri-wdio", "full-mac"] },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "coverage": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "riskAreas": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "changePatterns": {
            "type": "array",
            "items": { "type": "string" }
          },
          "knownGaps": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "currentSpec": { "type": ["string", "null"] },
          "currentScript": { "type": ["string", "null"] },
          "status": { "type": "string" },
          "requiredForDefaultPrPack": { "type": "boolean" }
        }
      }
    }
  }
}
