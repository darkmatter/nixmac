{
  "name": "native",
  "version": "0.22.0",
  "private": true,
  "type": "module",
  "imports": {
    "#storybook/*": ".storybook/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "desktop:dev": "tauri dev --config src-tauri/tauri.conf.dev.json",
    "desktop:build": "tauri build",
    "desktop:test": "cargo test --manifest-path src-tauri/Cargo.toml && bun run test:unit",
    "lint": "oxlint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:storybook": "vitest run --project=storybook --no-file-parallelism --maxWorkers=1",
    "test:storybook:ci": "node scripts/run-storybook-tests-ci.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:update": "vitest run --update",
    "test:update-snapshots": "vitest run --project=storybook --no-file-parallelism --maxWorkers=1 --update",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui-host=127.0.0.1 --ui-port=7777",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:e2e:ui:app": "playwright test --ui",
    "test:wdio:services": "process-compose -f e2e-tauri/process-compose.yaml up",
    "test:wdio": "node scripts/run-wdio-tests.mjs",
    "build:e2e": "tsc -p e2e-tauri/tsconfig.json",
    "test:wdio:smoke": "npm run build:e2e && wdio run e2e-tauri/wdio.smoke.conf.mjs",
    "test:wdio:basic-prompts": "npm run build:e2e && wdio run e2e-tauri/wdio.basic-prompts.conf.mjs",
    "test:wdio:conversational": "npm run build:e2e && wdio run e2e-tauri/wdio.conversational.conf.mjs",
    "test:wdio:discard": "npm run build:e2e && wdio run e2e-tauri/wdio.discard.conf.mjs",
    "test:wdio:modify": "npm run build:e2e && wdio run e2e-tauri/wdio.modify.conf.mjs",
    "test:wdio:manual-changes": "npm run build:e2e && wdio run e2e-tauri/wdio.manual-changes.conf.mjs",
    "test:wdio:onboarding": "npm run build:e2e && wdio run e2e-tauri/wdio.onboarding.conf.mjs",
    "generate": "bun run gen:schemas",
    "gen:schemas": "cargo run -- gen-schemas",
    "gen:orpc": "cargo run --manifest-path src-tauri/Cargo.toml -- gen-orpc"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@nixmac/state": "workspace:*",
    "@nixmac/ui": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@orpc-rs/tauri": "^1.1.0",
    "@orpc/client": "^1.14.6",
    "@orpc/tanstack-query": "^1.14.6",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@shikijs/transformers": "^3.20.0",
    "@tanstack/react-form": "^1.28.0",
    "@tanstack/react-query": "^5.101.1",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@vueless/storybook-dark-mode": "^10.0.8",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "execa": "^9.6.0",
    "immer": "^11.1.8",
    "lottie-react": "^2.4.1",
    "lucide-react": "^1.14.0",
    "monaco-editor": "^0.55.1",
    "monaco-editor-textmate": "^4.0.0",
    "monaco-textmate": "^3.0.1",
    "motion": "^12.35.2",
    "nostics": "^1.1.4",
    "onigasm": "^2.2.5",
    "posthog-js": "^1.382.0",
    "react": "^19.2.3",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.20.0",
    "sonner": "^2.0.7",
    "sudo-prompt": "^9.2.1",
    "tauri-plugin-macos-permissions-api": "^2.3.0",
    "three": "^0.184.0",
    "vscode-oniguruma": "^2.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-onboarding": "^10.4.2",
    "@storybook/addon-vitest": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/browser": "^3.0.0",
    "@vitest/coverage-istanbul": "3.2.4",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "clsx": "^2.1.1",
    "creevey": "0.11.4",
    "eslint-plugin-storybook": "10.4.2",
    "expect-webdriverio": "^5.6.5",
    "jsdom": "^27.3.0",
    "playwright": "1.59.1",
    "postcss": "^8.5.6",
    "react-style-singleton": "^2.2.3",
    "storybook": "^10.4.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.2.2",
    "vite": "^7.2.4",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vitest": "^3.0.0"
  }
}
