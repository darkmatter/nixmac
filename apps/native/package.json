{
  "name": "native",
  "version": "0.22.0",
  "private": true,
  "type": "module",
  "imports": {
    "#storybook/*": ".storybook/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:sidecars": "node scripts/build-tauri-sidecars.mjs",
    "sign:local-app": "sops exec-env ../../ops/secrets/secrets.sops.json 'bash ../../ops/scripts/release/sign-local-app.sh'",
    "desktop:dev": "tauri dev --config src-tauri/tauri.conf.dev.json",
    "desktop:build": "bun run build:sidecars && tauri build --config '{\"bundle\":{\"externalBin\":[\"binaries/nixmac-helper\",\"binaries/nixmac-sync-agent\"]}}'",
    "desktop:build:local": "bun run build:sidecars && tauri build --bundles app --config '{\"bundle\":{\"createUpdaterArtifacts\":false,\"externalBin\":[\"binaries/nixmac-helper\",\"binaries/nixmac-sync-agent\"]}}' && bun run sign:local-app",
    "desktop:test": "cargo test --manifest-path src-tauri/Cargo.toml && bun run test:unit",
    "lint": "oxlint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:storybook": "vitest run --project=storybook --no-file-parallelism --maxWorkers=1",
    "test:storybook:ci": "node scripts/run-storybook-tests-ci.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:update": "vitest run --update",
    "test:update-snapshots": "vitest run --project=storybook --no-file-parallelism --maxWorkers=1 --update",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui-host=127.0.0.1 --ui-port=7777",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:e2e:ui:app": "playwright test --ui",
    "test:wdio:services": "process-compose -f e2e-tauri/process-compose.yaml up",
    "test:wdio": "node scripts/run-wdio-tests.mjs",
    "build:e2e": "tsc -p e2e-tauri/tsconfig.json",
    "test:wdio:smoke": "npm run build:e2e && wdio run e2e-tauri/wdio.smoke.conf.mjs",
    "test:wdio:basic-prompts": "npm run build:e2e && wdio run e2e-tauri/wdio.basic-prompts.conf.mjs",
    "test:wdio:conversational": "npm run build:e2e && wdio run e2e-tauri/wdio.conversational.conf.mjs",
    "test:wdio:discard": "npm run build:e2e && wdio run e2e-tauri/wdio.discard.conf.mjs",
    "test:wdio:modify": "npm run build:e2e && wdio run e2e-tauri/wdio.modify.conf.mjs",
    "test:wdio:manual-changes": "npm run build:e2e && wdio run e2e-tauri/wdio.manual-changes.conf.mjs",
    "test:wdio:onboarding": "npm run build:e2e && wdio run e2e-tauri/wdio.onboarding.conf.mjs",
    "generate": "bun run gen:schemas",
    "gen:schemas": "cargo run --manifest-path src-tauri/Cargo.toml --bin nixmac -- gen-schemas",
    "gen:orpc": "cargo run --manifest-path src-tauri/Cargo.toml --bin nixmac -- gen-orpc",
    "gen:docs-index": "cargo run --manifest-path src-tauri/Cargo.toml --bin nixmac -- gen-docs-index"
  },
  "dependencies": {
    "@daveyplate/better-auth-tauri": "0.1.9",
    "@fontsource-variable/geist-mono": "5.2.8",
    "@fontsource-variable/inter": "5.2.8",
    "@monaco-editor/react": "4.7.0",
    "@nixmac/state": "workspace:*",
    "@nixmac/ui": "workspace:*",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-trace-web": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "@orpc-rs/tauri": "1.1.0",
    "@orpc/client": "1.14.6",
    "@orpc/tanstack-query": "1.14.6",
    "@radix-ui/react-icons": "1.3.2",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@tanstack/query-async-storage-persister": "5.101.1",
    "@tanstack/react-form": "1.29.1",
    "@tanstack/react-query": "5.101.1",
    "@tanstack/react-query-persist-client": "5.101.1",
    "@tanstack/react-router": "1.170.16",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-deep-link": "2.4.9",
    "@tauri-apps/plugin-http": "2.5.9",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@tauri-apps/plugin-os": "2.3.2",
    "@tauri-apps/plugin-shell": "2.3.5",
    "@tauri-apps/plugin-store": "2.4.3",
    "better-auth": "1.6.22",
    "execa": "9.6.1",
    "lottie-react": "2.4.1",
    "lucide-react": "1.14.0",
    "monaco-editor": "0.55.1",
    "monaco-editor-textmate": "4.0.0",
    "monaco-textmate": "3.0.1",
    "motion": "12.38.0",
    "nostics": "1.1.4",
    "onigasm": "2.2.5",
    "posthog-js": "1.382.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "sonner": "2.0.7",
    "sudo-prompt": "9.2.1",
    "tauri-plugin-macos-permissions-api": "2.3.0",
    "three": "0.184.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@storybook/addon-a11y": "10.4.2",
    "@storybook/addon-docs": "10.4.2",
    "@storybook/addon-onboarding": "10.4.2",
    "@storybook/addon-vitest": "10.4.2",
    "@storybook/react-vite": "10.4.2",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.1",
    "@tauri-apps/cli": "2.11.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.1",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-istanbul": "3.2.4",
    "@wdio/cli": "9.27.1",
    "@wdio/globals": "9.27.1",
    "@wdio/local-runner": "9.27.1",
    "@wdio/mocha-framework": "9.27.1",
    "@wdio/spec-reporter": "9.27.1",
    "babel-plugin-react-compiler": "1.0.0",
    "chai": "6.2.2",
    "chai-as-promised": "8.0.2",
    "clsx": "2.1.1",
    "creevey": "0.11.4",
    "expect-webdriverio": "5.6.5",
    "jsdom": "27.4.0",
    "playwright": "1.59.1",
    "storybook": "10.4.2",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-plugin-monaco-editor": "1.1.0",
    "vitest": "3.2.4"
  }
}
