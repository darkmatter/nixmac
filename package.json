{
  "name": "nixmac",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "vendor/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@trpc/server": "^11.7.2",
      "better-auth": "1.4.5",
      "@trpc/client": "^11.7.2",
      "@polar-sh/better-auth": "^1.1.3",
      "drizzle-orm": "^0.45.1",
      "@types/pg": "^8.15.6"
    }
  },
  "type": "module",
  "scripts": {
    "check": "oxlint .",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "desktop:dev": "turbo -F native desktop:dev",
    "desktop:build": "turbo -F native desktop:build",
    "db:push": "turbo -F @nixmac/db db:push",
    "db:studio": "turbo -F @nixmac/db db:studio",
    "db:generate": "turbo -F @nixmac/db db:generate",
    "db:migrate": "turbo -F @nixmac/db db:migrate",
    "postinstall": "bun2nix -o bun.nix",
    "devenv:up": "bash ./bin/devenv-up"
  },
  "dependencies": {
    "@biomejs/biome": "^2.3.13",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@tauri-apps/plugin-upload": "^2.4.0",
    "cmdk": "^1.1.1",
    "dotenv": "catalog:",
    "oxfmt": "^0.20.0",
    "znv": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251213.0",
    "@types/bun": "catalog:",
    "bun2nix": "^2.0.6",
    "oxlint": "^1.0.0",
    "sonner": "^2.0.7",
    "turbo": "^2.7.2",
    "typescript": "^5",
    "ultracite": "6.4.0"
  },
  "packageManager": "bun@1.3.2",
  "version": "0.5.0"
}
