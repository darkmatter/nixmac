{
  "name": "nixmac",
  "private": true,
  "workspaces": [
    "apps/native",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "check": "oxlint .",
    "dev": "if [ \"$STORYBOOK_DEV\" = \"true\" ]; then bun -F native storybook; else bun -F native dev; fi",
    "desktop:dev": "bun -F native desktop:dev",
    "desktop:build": "bun -F native desktop:build",
    "desktop:test": "bun -F native desktop:test",
    "postinstall": "test -n \"$SKIP_POSTINSTALL\" || bun2nix -o bun.nix",
    "release": "release-it",
    "test:e2e": "bun -F native test:e2e",
    "test:e2e:ui": "bun -F native test:e2e:ui",
    "test:e2e:install": "bun -F native test:e2e:install",
    "knip": "knip"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.6.0",
    "bun2nix": "^2.0.6",
    "danger": "^12.3.3",
    "knip": "^6.11.0",
    "oxlint": "^1.0.0",
    "release-it": "^19.0.3",
    "typescript": "^6.0.3",
    "ultracite": "6.4.0"
  },
  "packageManager": "bun@1.3.2",
  "version": "0.22.0",
  "dependencies": {
    "effect": "^4.0.0-beta.62"
  },
  "overrides": {
    "cpu-features": "npm:noop2@^2.0.0"
  }
}
