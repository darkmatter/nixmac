{
  "name": "nixmac",
  "version": "0.22.0",
  "private": true,
  "workspaces": [
    "apps/native",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "gen": "turbo gen",
    "check": "oxlint .",
    "dev": "bun -F native dev",
    "desktop:dev": "bun -F native desktop:dev",
    "desktop:build": "bun -F native desktop:build",
    "desktop:test": "bun -F native desktop:test",
    "postinstall": "bun2nix -o bun.nix",
    "release": "release-it",
    "test:e2e": "bun -F native test:e2e",
    "test:e2e:ui": "bun -F native test:e2e:ui",
    "test:e2e:install": "bun -F native test:e2e:install",
    "check:agent-docs": "node scripts/check-agent-docs.mjs",
    "knip": "knip"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "25.6.0",
    "bun2nix": "2.0.8",
    "danger": "12.3.4",
    "knip": "6.11.0",
    "oxlint": "1.63.0",
    "release-it": "19.2.4",
    "turbo": "2.9.18",
    "typescript": "6.0.3"
  },
  "overrides": {
    "cpu-features": "npm:noop2@2.0.0"
  },
  "packageManager": "bun@1.3.14"
}
