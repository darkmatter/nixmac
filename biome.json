{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "apps/**",
      "packages/**",
      "*.json",
      "*.ts",
      "*.tsx",
      "*.js",
      "*.jsx"
    ]
  },
  "extends": ["ultracite/core", "ultracite/react"]
}
