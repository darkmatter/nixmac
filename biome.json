{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",

  "linter": {
    "rules": {
      "style": {
        "useConsistentTypeDefinitions": "warn"
      }
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "apps/**",
      "packages/**",
      "*.json",
      "*.ts",
      "*.tsx",
      "*.js",
      "*.jsx",
      "!**/.devenv",
      "!**/.devenv*",
      "!**/.git",
      "!**/.github",
      "!**/.ruler",
      "!**/.vscode",
      "!**/.env*",
      "!**/.env.local*",
      "!**/.env.development.local*",
      "!**/.env.test.local*",
      "!**/.env.production.local*",
      "!**/.turbo",
      "!**/node_modules",
      "!**/target",
      "!**/src-tauri/target",
      "!**/src-tauri/gen",
      "!**/dist",
      "!**/dist-ssr",
      "!**/build",
      "!**/.cache",
      "!**/coverage",
      "!**/.alchemy"
    ]
  },
  "extends": ["ultracite/core", "ultracite/react"]
}
