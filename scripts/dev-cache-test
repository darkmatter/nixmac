#!/usr/bin/env bash
# scripts/dev-cache-test
#
# Temporary workflow for exercising the devenv profile cache.
# Safe to run repeatedly — no destructive side effects beyond task execution
# in `full` mode (which is what `devenv shell` would do anyway).
#
# Usage:
#   scripts/dev-cache-test check   # hash check only (fast: ~100ms warm)
#   scripts/dev-cache-test full    # hash + full devenv shell + direnv
#   scripts/dev-cache-test cold    # force eval cache refresh (~17s)
#   scripts/dev-cache-test warm    # warm eval cache (~100ms)
#   scripts/dev-cache-test miss    # simulate miss: touch devenv.nix, then check
#   scripts/dev-cache-test all     # run all modes in sequence
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

hr() { printf '\n\033[1;36m--- %s ---\033[0m\n' "$*"; }

run_check() {
  hr "Hash check (scripts/devenv-hash)"
  time "$root/scripts/devenv-hash" || true
}

run_full() {
  run_check
  hr "Full devenv shell --no-tui --quiet"
  time devenv shell --no-tui --quiet echo noop-full || true
  hr "direnv export bash"
  time direnv export bash >/dev/null || true
}

run_cold() {
  hr "Cold eval (--refresh-eval-cache)"
  time devenv eval --no-tui --quiet --refresh-eval-cache devenv.profile || true
}

run_warm() {
  hr "Warm eval (cached)"
  time devenv eval --no-tui --quiet devenv.profile || true
}

run_miss() {
  hr "True miss via --option packages:pkgs hello (eval-only, no build)"
  local current expected_with_hello
  current=$(readlink "$root/.devenv/profile" 2>/dev/null || echo "(none)")
  expected_with_hello=$(devenv eval --no-tui --quiet \
    --option packages:pkgs hello devenv.profile 2>/dev/null \
    | grep -oE '/nix/store/[a-z0-9]+-devenv-profile' | head -1)
  echo "current (built):    $current"
  echo "expected (+hello):  $expected_with_hello"
  if [[ "$current" != "$expected_with_hello" ]]; then
    echo "STATUS: miss (paths differ — config change detected)"
  else
    echo "STATUS: unexpected hit"
  fi

  hr "Recheck with real config (should hit)"
  time "$root/scripts/devenv-hash" || true
}

mode="${1:-check}"
case "$mode" in
  check) run_check ;;
  full)  run_full ;;
  cold)  run_cold ;;
  warm)  run_warm ;;
  miss)  run_miss ;;
  all)
    run_warm
    run_check
    run_miss
    run_cold
    run_full
    ;;
  -h|--help)
    sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
    ;;
  *) echo "Usage: $0 {check|full|cold|warm|miss|all}" >&2; exit 1 ;;
esac
