#!/usr/bin/env bash
# scripts/devenv-hash
#
# Authoritative nix-invoked hash for the devenv profile.
# Compares what nix WOULD build (via `devenv eval devenv.profile`) against
# what is currently symlinked at .devenv/profile AND what the current shell
# has loaded via DEVENV_PROFILE.
#
# Three-state check:
#   1. expected (nix eval) vs symlink  → is profile on disk current?
#   2. symlink vs DEVENV_PROFILE env    → is shell env fresh?
#
# Exit codes:
#   0  fresh   — profile current AND shell env matches → safe to build
#   1  stale    — profile current but shell env old → direnv reload needed
#   2  miss     — profile out of date → devenv rebuild needed
#   3  error    — eval failed or no profile yet
#
# Output (stdout): "<fresh|stale|miss> <expected> <symlink> [shell-env]"
#
# Timing:
#   ~100ms warm (eval cache hit)
#   ~2-17s cold (eval cache miss — depends on which config file changed)
#
# Usage:
#   scripts/devenv-hash                 # check + exit code
#   scripts/devenv-hash --raw           # just print expected store path
#   scripts/devenv-hash --json          # machine-readable status
set -euo pipefail

root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$root"

raw=0
json=0
for arg in "$@"; do
  case "$arg" in
    --raw)  raw=1 ;;
    --json) json=1 ;;
    -h|--help)
      sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *) echo "unknown arg: $arg" >&2; exit 3 ;;
  esac
done

profile_link="$root/.devenv/profile"

# Currently-built profile (what the symlink points at, if any)
symlinked=""
if [[ -L "$profile_link" ]]; then
  symlinked=$(readlink "$profile_link")
fi

# Expected profile (what nix would build right now).
# `devenv eval` is authoritative — uses nix evaluation, honors eval cache.
# Output JSON shape: { "devenv.profile": "/nix/store/<hash>-devenv-profile" }
expected_json=$(devenv eval --no-tui --quiet devenv.profile 2>/dev/null || true)
expected=$(printf '%s' "$expected_json" \
  | grep -oE '/nix/store/[a-z0-9]+-devenv-profile' \
  | head -1)

if [[ -z "$expected" ]]; then
  if [[ $json -eq 1 ]]; then
    printf '{"status":"error","reason":"eval returned no profile"}\n'
  else
    echo "error: devenv eval returned no profile path" >&2
  fi
  exit 3
fi

if [[ $raw -eq 1 ]]; then
  printf '%s\n' "$expected"
  exit 0
fi

json_escape() {
  local s=$1
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  s=${s//$'\n'/\\n}
  s=${s//$'\r'/\\r}
  s=${s//$'\t'/\\t}
  printf '%s' "$s"
}

# Shell env: what devenv set when this shell was entered.
shell_env="${DEVENV_PROFILE:-}"

# State 1: profile symlink vs expected (nix eval)
if [[ "$symlinked" != "$expected" ]]; then
  # Profile on disk is out of date — config changed, need rebuild
  if [[ $json -eq 1 ]]; then
    printf '{"status":"miss","expected":"%s","symlink":"%s"}\n' \
      "$(json_escape "$expected")" "$(json_escape "$symlinked")"
  else
    printf 'miss expected=%s symlink=%s\n' "$expected" "$symlinked"
  fi
  exit 2
fi

# State 2: symlink is current, but is the shell env fresh?
if [[ -n "$shell_env" && "$shell_env" != "$expected" ]]; then
  # Profile rebuilt but shell hasn't re-entered (direnv hasn't reloaded)
  if [[ $json -eq 1 ]]; then
    printf '{"status":"stale","profile":"%s","shell_env":"%s"}\n' \
      "$(json_escape "$expected")" "$(json_escape "$shell_env")"
  else
    printf 'stale profile=%s shell_env=%s\n' "$expected" "$shell_env"
  fi
  exit 1
fi

# State 3: everything matches — safe to build
if [[ $json -eq 1 ]]; then
  printf '{"status":"fresh","profile":"%s"}\n' "$(json_escape "$expected")"
else
  printf 'fresh %s\n' "$expected"
fi
exit 0
