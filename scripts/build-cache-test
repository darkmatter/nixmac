#!/usr/bin/env bash
# scripts/build-cache-test
#
# Tests devenv-hash against the real macOS app build.
# Verifies the hash reliably predicts whether the devenv shell
# is fresh enough to build the Tauri app.
#
# Usage:
#   scripts/build-cache-test              # debug build (faster)
#   scripts/build-cache-test release      # release build
#   scripts/build-cache-test check-only   # just hash + cargo check
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

mode="${1:-debug}"
hr() { printf '\n\033[1;36m--- %s ---\033[0m\n' "$*"; }

# Env vars the Rust build consumes from devenv.
# If these drift (profile miss), the build will use wrong compiler/SDK/deps.
DEP_ENV_VARS=(
  NIX_CC
  NIX_CC_FOR_BUILD
  NIX_BINTOOLS
  NIX_LDFLAGS
  NIX_CFLAGS_COMPILE
  SDKROOT
  DEVELOPER_DIR
  LIBRARY_PATH
  DYLD_LIBRARY_PATH
  RUST_SRC_PATH
  PLAYWRIGHT_BROWSERS_PATH
  PATH
)

print_build_env() {
  hr "Build-critical env vars from devenv"
  for var in "${DEP_ENV_VARS[@]}"; do
    val="${!var:-<unset>}"
    # Truncate long values
    if [[ ${#val} -gt 80 ]]; then
      val="${val:0:77}..."
    fi
    printf '  %s=%s\n' "$var" "$val"
  done
}

hash_check() {
  hr "devenv-hash check"
  local start end elapsed output exit_code
  start=$(date +%s%N)
  output=$("$root/scripts/devenv-hash" 2>&1) && exit_code=0 || exit_code=$?
  end=$(date +%s%N)
  elapsed=$(( (end - start) / 1000000 ))
  local status
  case $exit_code in
    0) status="fresh" ;;
    1) status="STALE" ;;
    2) status="MISS" ;;
    *) status="error" ;;
  esac
  printf '%s (%dms, exit=%d): %s\n' "$status" "$elapsed" "$exit_code" "$output"
  if [[ $exit_code -eq 1 ]]; then
    echo "  -> Shell env is from old profile. Build will use WRONG compiler/SDK."
    echo "  -> Fix: direnv reload  (or open a new shell)"
  fi
  if [[ $exit_code -eq 2 ]]; then
    echo "  -> Profile is out of date. Must rebuild devenv."
    echo "  -> Fix: devenv shell"
  fi
}

run_build() {
  local build_cmd
  if [[ "$mode" == "release" ]]; then
    build_cmd="bun run desktop:build"
  elif [[ "$mode" == "check-only" ]]; then
    build_cmd="cargo check --manifest-path apps/native/src-tauri/Cargo.toml"
  else
    build_cmd="cd apps/native && bun run tauri build --debug"
  fi
  hr "Build: $build_cmd"
  time eval "$build_cmd"
}

verify_env_unchanged() {
  hr "Verify build env unchanged after build"
  # The build should NOT change any devenv config files
  local changed
  changed=$(git status --porcelain devenv.nix devenv.yaml devenv.lock nix/ .env 2>/dev/null | wc -l | tr -d ' ')
  if [[ "$changed" == "0" ]]; then
    echo "OK: no devenv config files changed during build"
  else
    echo "WARN: devenv config files changed:"
    git status --porcelain devenv.nix devenv.yaml devenv.lock nix/ .env 2>/dev/null
  fi
}

simulate_miss() {
  hr "Simulate config change (miss detection)"
  local expected_with_extra
  expected_with_extra=$(devenv eval --no-tui --quiet \
    --option packages:pkgs hello devenv.profile 2>/dev/null \
    | grep -oE '/nix/store/[a-z0-9]+-devenv-profile' | head -1)
  local current
  current=$(readlink "$root/.devenv/profile" 2>/dev/null || echo "(none)")
  echo "current (built):         $current"
  echo "expected (+pkgs.hello):  $expected_with_extra"
  if [[ "$current" != "$expected_with_extra" ]]; then
    echo "STATUS: miss — config change detected, rebuild needed"
  else
    echo "STATUS: unexpected hit"
  fi
}

check_stale_env() {
  hr "Stale env detection (the real build-killer)"
  local symlink shell_env
  symlink=$(readlink "$root/.devenv/profile" 2>/dev/null || echo "(none)")
  shell_env="${DEVENV_PROFILE:-<unset>}"
  echo "Profile symlink:  $symlink"
  echo "Shell DEVENV_PROFILE: $shell_env"
  if [[ "$symlink" != "$shell_env" ]]; then
    echo "STATUS: STALE — shell env is from old profile"
    echo "  Build will use wrong NIX_CC, SDKROOT, swift-wrapper etc."
    echo "  This is what causes build failures like 'swift-build: not found'"
    echo "  Fix: direnv reload"
  else
    echo "STATUS: fresh — shell env matches profile"
  fi
}

# --- Main ---
hash_check
check_stale_env
print_build_env
run_build
verify_env_unchanged
hash_check
simulate_miss

hr "Summary"
echo "Build mode: $mode"
echo ""
echo "Three-state check:"
echo "  fresh  → profile current, shell env matches → safe to build"
echo "  stale  → profile current, shell env old → direnv reload first"
echo "  miss   → profile out of date → devenv rebuild first"
echo ""
echo "The swift-build failure was caused by STALE env — shell used old"
